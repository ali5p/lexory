GENERATOR_MODE=llm
OLLAMA_MODEL=qwen2.5:1.5b-instruct
# OLLAMA_STRUCTURED_OUTPUT=0
# OLLAMA_TIMEOUT=120

# For uvicorn on the host with backends in Docker (published ports), use localhost:
OLLAMA_URL=http://localhost:11434/api/generate
QDRANT_URL=http://localhost:6333
LANGUAGETOOL_URL=http://localhost:8010
DATABASE_URL=postgresql+asyncpg://lexory:lexory@localhost:5432/lexory
# In Docker, if DATABASE_URL uses localhost (e.g. from this file), it is rewritten to
# POSTGRES_HOST (default postgres). docker-compose.yml also sets DATABASE_URL to @postgres:5432.

# docker-compose.yml sets QDRANT_URL / OLLAMA_URL / LANGUAGETOOL_URL / DATABASE_URL
# to service names for the lexory container — it does not use these localhost values.