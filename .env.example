GENERATOR_MODE=llm
OLLAMA_MODEL=qwen2:1.5b

# For uvicorn on the host with backends in Docker (published ports), use localhost:
OLLAMA_URL=http://localhost:11434/api/generate
QDRANT_URL=http://localhost:6333
LANGUAGETOOL_URL=http://localhost:8010

# docker-compose.yml sets QDRANT_URL / OLLAMA_URL / LANGUAGETOOL_URL to service names
# for the lexory container — it does not use these localhost values for that service.